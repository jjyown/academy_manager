# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Edge verify-teacher-pin 호출용(채점 세션 발급). Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=

# 채점 관리 브라우저용 단기 JWT (숙제 조회 API 보호). 16자 이상 난수 권장. 비우면 숙제 API는 teacher_id 쿼리 폴백(개발용)
GRADING_SESSION_SECRET=
GRADING_SESSION_TTL_HOURS=12

# (선택) 다른 /api/* 보호용. 설정 시 Bearer(Supabase JWT) 필요 — homework/grading-auth 경로는 예외
SUPABASE_JWT_SECRET=

# Google OAuth (중앙 드라이브 jjyown@gmail.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (GPT-4o OCR)
OPENAI_API_KEY=your-openai-api-key

# Server
PORT=8000

# 중앙 드라이브: 숙제 관리 / 교재/{중1~고3} / 제출 과제 원본 / 채점 결과 (자동 생성)
# Edge upload-homework는 루트명이 "숙제 관리" 고정. Railway 여기를 "과제 관리"로 두면 채점 결과만 다른 루트로 갈 수 있음.
CENTRAL_ROOT_FOLDER=숙제 관리
# 쉼표 구분. My Drive에 "숙제 관리"가 없고 아래 이름만 있으면 그 폴더를 루트로 사용(로그 경고).
CENTRAL_ROOT_FOLDER_LEGACY_ALIASES=과제 관리
CENTRAL_GRADING_MATERIAL_FOLDER=교재
CENTRAL_GRADED_RESULT_FOLDER=채점 결과
CENTRAL_SUBMIT_FOLDER=제출 과제 원본
# 교재 파싱 페이지 이미지: 숙제 관리/교재/이 폴더/{교재제목}
CENTRAL_PAGE_IMAGES_FOLDER=교재 페이지 이미지
# 쉼표 구분 학년 폴더명
CENTRAL_GRADE_LEVEL_FOLDERS=중1,중2,중3,고1,고2,고3

# 원본 보관 기간 (일)
ORIGINAL_KEEP_DAYS=30

# 채점 이미지 품질 (1~100)
IMAGE_QUALITY=80

# 채점 전체 타임아웃(초): base + per_image * 이미지수, 최대 max
GRADING_TIMEOUT_BASE_SECONDS=300
GRADING_TIMEOUT_PER_IMAGE_SECONDS=20
GRADING_TIMEOUT_MAX_SECONDS=900

# OCR 타이브레이크 안전장치
OCR_TIEBREAK_MAX_ITEMS_PER_IMAGE=6
OCR_TIEBREAK_MAX_RETRIES_PER_QUESTION=1
OCR_TIEBREAK_FALLBACK_ON_REFUSAL=true

# AI 에이전트 검증 보호장치
AGENT_VERIFY_HARD_TIMEOUT_SECONDS=180
AGENT_VERIFY_MAX_QUESTIONS=12
AGENT_VERIFY_MIN_REMAINING_SECONDS=45
AGENT_VERIFY_TIMEOUT_GUARD_SECONDS=20
