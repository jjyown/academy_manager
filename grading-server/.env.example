# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Edge verify-teacher-pin 호출용(채점 세션 발급). Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=

# 채점 관리 브라우저용 단기 JWT (숙제 조회 API 보호). 16자 이상 난수 권장. 비우면 숙제 API는 teacher_id 쿼리 폴백(개발용)
GRADING_SESSION_SECRET=
GRADING_SESSION_TTL_HOURS=12
# true(기본): PIN 없이 POST /api/grading-auth/session-open 허용. 공개 URL에 채점 페이지가 있으면 false 권장.
GRADING_ALLOW_OPEN_GRADING_SESSION=true
# session-open 시 teachers 행 선택용(이메일 일치). 프론트 canonical 이메일과 동일하게.
GRADING_CANONICAL_OWNER_EMAIL=jjyown@gmail.com

# (선택) 다른 /api/* 보호용. 설정 시 Bearer(Supabase JWT) 필요 — homework/grading-auth 경로는 예외
SUPABASE_JWT_SECRET=

# Google OAuth (중앙 드라이브 jjyown@gmail.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (GPT-4o OCR)
OPENAI_API_KEY=your-openai-api-key

# ============================================================
# Mathpix OCR (인쇄된 정답 PDF / 교재 페이지 OCR 1순위)
# ============================================================
# 자격증명이 설정되면 정답 PDF 파싱(grading/pdf_parser.py)이 Mathpix → Gemini 순으로 시도한다.
# 충전량(callsRemaining)이 MATHPIX_LOW_THRESHOLD 이하이거나 quota 에러를 받으면
# 자동으로 exhausted 상태가 되어 Gemini Vision으로 폴백한다.
# 학생 답안 손글씨 OCR은 Gemini+GPT-4o 파이프라인을 유지(Mathpix 미사용).
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
# 기본값으로 충분(자체 호스팅 시에만 변경)
MATHPIX_API_BASE=https://api.mathpix.com
# 잔여 호출 수가 이 값 이하이면 사전 차단(폴백 경로로 우회)
# ⚠ 2025년 이후 Mathpix는 잔여 호출 수를 API로 제공하지 않으므로 사전 차단은 사실상 동작하지 않는다.
#    실제 차단은 호출 후 quota error(402/403, "out of credit")가 감지될 때 발생한다.
#    충전량은 https://console.mathpix.com 에서 직접 확인할 것.
MATHPIX_LOW_THRESHOLD=50
# exhausted 후 자동 재시도 대기(분). 비우면 영구 비활성(수동 reset 필요)
# 충전 후 재활성: GET /api/mathpix-status?resetExhaustion=1
MATHPIX_RETRY_AFTER_EXHAUSTION_MIN=
# PDF 변환 폴링 timeout / 폴링 간격(초)
MATHPIX_PDF_TIMEOUT_SECONDS=300
MATHPIX_PDF_POLL_INTERVAL_SECONDS=3
# 정답 PDF 추출 1순위 엔진(공란 = Mathpix 자격증명 유무로 자동 결정)
# 값: "mathpix" | "gemini"
PDF_EXTRACTION_PRIMARY=

# ============================================================
# 외부 해설 시스템 연동 (highroad-math-solution / 시험지 해설 제작)
# ============================================================
# 별도 Supabase 프로젝트의 검수 완료 해설(exam_solutions / analysis_records)
# 을 채점 결과·학생 포털에 노출. 두 변수 모두 비워두면 비활성화(현재와 동일 동작).
# - URL 예: https://<solution-project-ref>.supabase.co
# - SERVICE KEY: 해설 프로젝트의 service_role 키(읽기 전용으로만 사용)
HIGHROAD_SOLUTION_SUPABASE_URL=
HIGHROAD_SOLUTION_SERVICE_KEY=
# 외부 호출 timeout(초). 응답이 늦으면 채점 화면이 늦어지므로 짧게.
HIGHROAD_SOLUTION_TIMEOUT_SEC=8

# Server
PORT=8000

# 중앙 드라이브: 숙제 관리 / 교재/{중1~고3} / 제출 과제 원본 / 채점 결과 (자동 생성)
# Edge upload-homework는 루트명이 "숙제 관리" 고정. Railway 여기를 "과제 관리"로 두면 채점 결과만 다른 루트로 갈 수 있음.
CENTRAL_ROOT_FOLDER=숙제 관리
# 쉼표 구분. My Drive에 "숙제 관리"가 없고 아래 이름만 있으면 그 폴더를 루트로 사용(로그 경고).
CENTRAL_ROOT_FOLDER_LEGACY_ALIASES=과제 관리
CENTRAL_GRADING_MATERIAL_FOLDER=교재
CENTRAL_GRADED_RESULT_FOLDER=채점 결과
# 즉시 채점(mode=instant): 숙제 관리 / 이 폴더 / 년·월·일 / 선생님 입력 폴더명
CENTRAL_INSTANT_GRADE_FOLDER=즉시채점
CENTRAL_SUBMIT_FOLDER=제출 과제 원본
# 교재 파싱 페이지 이미지: 숙제 관리/교재/이 폴더/{교재제목}
CENTRAL_PAGE_IMAGES_FOLDER=교재 페이지 이미지
# 쉼표 구분 학년 폴더명
CENTRAL_GRADE_LEVEL_FOLDERS=중1,중2,중3,고1,고2,고3

# 원본 보관 기간 (일)
ORIGINAL_KEEP_DAYS=30

# 채점 이미지 품질 (1~100)
IMAGE_QUALITY=80

# 채점 전체 타임아웃(초): base + per_image * 이미지수, 최대 max
GRADING_TIMEOUT_BASE_SECONDS=300
GRADING_TIMEOUT_PER_IMAGE_SECONDS=20
GRADING_TIMEOUT_MAX_SECONDS=900

# OCR 타이브레이크 안전장치
OCR_TIEBREAK_MAX_ITEMS_PER_IMAGE=6
OCR_TIEBREAK_MAX_RETRIES_PER_QUESTION=1
OCR_TIEBREAK_FALLBACK_ON_REFUSAL=true

# AI 에이전트 검증 보호장치
AGENT_VERIFY_HARD_TIMEOUT_SECONDS=180
AGENT_VERIFY_MAX_QUESTIONS=12
AGENT_VERIFY_MIN_REMAINING_SECONDS=45
AGENT_VERIFY_TIMEOUT_GUARD_SECONDS=20
