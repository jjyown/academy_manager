{
  "framework": null,
  "buildCommand": "echo 'Static site'",
  "installCommand": "npm install --no-audit --no-fund",
  "outputDirectory": ".",
  "name": "highroad-math",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://academymanager-production.up.railway.app/api/:path*" },
    { "source": "/homework", "destination": "/homework/index.html" },
    { "source": "/homework/", "destination": "/homework/index.html" },
    { "source": "/grading", "destination": "/grading/index.html" },
    { "source": "/grading/", "destination": "/grading/index.html" },
    { "source": "/parent-portal", "destination": "/parent-portal/index.html" },
    { "source": "/parent-portal/", "destination": "/parent-portal/index.html" }
  ]
}
